rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Règle universelle pour Notes, Dossiers et Fichiers
    match /{collectionName}/{docId} {
      
      // Lecture et Suppression : autorisé si vous êtes le propriétaire
      allow read, delete: if request.auth != null 
        && resource.data.userId == request.auth.uid;
      
      // Création : autorisé si vous êtes connecté et que vous vous désignez comme propriétaire
      allow create: if request.auth != null 
        && request.resource.data.userId == request.auth.uid;
        
      // Mise à jour (Update) : autorisé si le document vous appartient déjà
      // On s'assure qu'on ne change pas le propriétaire (userId) lors de la modification
      allow update: if request.auth != null 
        && resource.data.userId == request.auth.uid
        && (request.resource.data.userId == request.auth.uid || !('userId' in request.resource.data));
    }
  }
}